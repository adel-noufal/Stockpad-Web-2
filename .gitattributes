# Normalize line endings: store as LF in the repo, checkout as
# native (CRLF on Windows, LF on Linux/macOS).
* text=auto

# Force LF for files that must stay LF everywhere
*.py    text eol=lf
*.sh    text eol=lf
*.md    text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
